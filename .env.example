DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tfm_task_client?schema=public"
AUTH_SECRET="replace-with-generated-secret"
BOOTSTRAP_USER_EMAIL="tu@email.com"
BOOTSTRAP_USER_PASSWORD="UnaPasswordSegura123!"
BOOTSTRAP_USER_NAME="Oscar"

# Milisegundos antes de auto-cerrar las alertas (0 = no auto-cerrar)
ALERT_AUTO_DISMISS_MS="5000"

# IA para los resúmenes de reporte (opcional). Sin ANTHROPIC_API_KEY se usa un
# resumen simulado por plantilla. AI_MODEL sobrescribe el modelo (por defecto Haiku 4.5).
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL="claude-haiku-4-5"   # por defecto (rápido/barato: ~$1/$5 por millón tok)
# AI_MODEL="claude-sonnet-4-6"  # equilibrio calidad/coste
# AI_MODEL="claude-opus-4-8"    # máxima calidad de redacción

# Versión mostrada en el footer. Fuente de verdad: APP_VERSION en src/lib/config.ts.
# Descomenta solo para forzar una versión distinta a la del código (poco habitual).
# APP_VERSION="0.0.0"
